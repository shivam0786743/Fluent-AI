{
  "info": {
    "name": "Fluent-Ai API",
    "description": "Postman Collection for LexExLearner/Fluent-Ai APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/user/signup",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"1234567890\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/user/verify-otp",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verificationId\": \"id_here\",\n  \"otp\": \"123456\",\n  \"phoneNumber\": \"1234567890\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/user/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"1234567890\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/user",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/user/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/user/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"native_language\": \"Hindi\",\n  \"daily_goal_minutes\": 30,\n  \"notifications_enabled\": true,\n  \"dark_mode\": false\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Level",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/user/level",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"level\": \"intermediate\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Avatar",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/user/avatar",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"avatar\": \"base64_string_here\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Add Selected Language",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/user/languages",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"English\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/user/logout"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"your_refresh_token_here\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Topics",
      "item": [
        {
          "name": "Get Topics Grouped By Category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/topics",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Recommended Topic",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/topics/recommended"
          }
        },
        {
          "name": "Get Topic By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/topics/{{topicId}}",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Admin - Create Topic",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/topics",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Topic Title\",\n  \"category\": \"Category\",\n  \"difficulty\": \"easy\",\n  \"is_premium\": false,\n  \"icon_url\": \"url\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Admin - Get All Topics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/topics/admin/all",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            }
          }
        },
        {
          "name": "Admin - Update Topic",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/topics/{{topicId}}",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Topic Title\",\n  \"category\": \"Updated Category\",\n  \"difficulty\": \"medium\",\n  \"is_premium\": false,\n  \"icon_url\": \"url\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Admin - Delete Topic",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/topics/{{topicId}}",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Start Session",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/sessions/start",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic_id\": \"topic_id_here\",\n  \"mode\": \"practice\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Session History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/sessions/history"
          }
        },
        {
          "name": "Complete Session",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/sessions/{{sessionId}}/complete",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grammar_score\": 80,\n  \"vocabulary_score\": 90,\n  \"pronunciation_score\": 85,\n  \"fluency_score\": 88,\n  \"duration_minutes\": 10\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/signup",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"0987654321\",\n  \"password\": \"adminpassword\",\n  \"name\": \"Admin Name\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"0987654321\",\n  \"password\": \"adminpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Admin Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/profile",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/progress/summary"
          }
        },
        {
          "name": "Get Fluency Trend",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/progress/fluency-trend"
          }
        },
        {
          "name": "Get Overall Score",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/progress/overall-score"
          }
        },
        {
          "name": "Get Skills Breakdown",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/progress/skills-breakdown"
          }
        },
        {
          "name": "Get Streak",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/progress/streak"
          }
        }
      ]
    },
    {
      "name": "Audio",
      "item": [
        {
          "name": "Text to Speech",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/audio/text-to-speech",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello world\",\n  \"voiceId\": \"en-US-natalie\",\n  \"format\": \"MP3\",\n  \"encodeAsBase64\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Speech to Text",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/audio/speech-to-text",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"audio\": \"base64_audio_here\",\n  \"model\": \"nova-2\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Voice to Voice",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/audio/voice-to-voice",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"audio\": \"base64_audio_here\",\n  \"voiceId\": \"en-US-natalie\",\n  \"systemInstruction\": \"You are a helpful language learning assistant on Fluent-Ai.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
